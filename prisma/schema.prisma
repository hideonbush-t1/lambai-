datasource db {
  provider = "postgresql" 
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            Int           @id @default(autoincrement())
  name          String
  email         String        @unique
  password      String        // Thêm trường này để lưu mật khẩu mã hóa
  role          Role          @default(MEMBER) // Đổi từ String sang sử dụng Enum Role
  groupId       Int?
  group         Group?        @relation(fields: [groupId], references: [id])
  createdAt     DateTime      @default(now())
  attempts      ExamAttempt[] 
}
model Group {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

enum Role {
  SUPER_ADMIN
  CONTENT_ADMIN
  MEMBER
  GUEST
}

model Exam {
  id          Int        @id @default(autoincrement())
  title       String    
  description String?
  questions   Question[] 
  createdAt   DateTime   @default(now())
}

model Question {
  id            String   @id @default(cuid())
  content       String   // Nội dung câu hỏi
  type          String   // MULTIPLE_CHOICE hoặc SCRIPTING (Monaco)
  options       Json?    // Các lựa chọn trắc nghiệm
  correctAnswer String?
  codeTemplate  String?  // Mẫu code ban đầu cho Monaco
  
  examId        Int
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model ExamAttempt {
  id        Int      @id @default(autoincrement())
  userId    Int      
  // Thêm onDelete: Cascade vào đây:
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score     Float
  createdAt DateTime @default(now())
}